# Backend — rode a partir de backend/ (ou copie para backend/.env)
OLLAMA_BASE=http://localhost:11434
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4:12b
OLLAMA_TIMEOUT=60
INGEST_ON_STARTUP=false
INGEST_BACKGROUND=false
ALLOW_SEED=true

# Obsidian — escolha UMA opção:
# Opção A (recomendada): plugin "Local REST API" no Obsidian → Settings → copie a API key
OBSIDIAN_REST_URL=https://127.0.0.1:27124
OBSIDIAN_REST_API_KEY=
OBSIDIAN_FOLDER=Tech-Pulse
OBSIDIAN_VERIFY_SSL=false
OBSIDIAN_OPEN_AFTER_EXPORT=true

# Opção B: gravação direta na pasta do vault (sem plugin)
# OBSIDIAN_VAULT_PATH=C:\Users\SEU_USUARIO\Documents\MeuVault
# OBSIDIAN_FOLDER=Tech-Pulse

# Frontend — copie para frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
