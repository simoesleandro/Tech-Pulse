# Copie para backend/.env e preencha OBSIDIAN_REST_API_KEY

OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
OLLAMA_TIMEOUT=180
OLLAMA_CONCURRENCY=3

# Plugin Local REST API (Obsidian → Settings → Community plugins)
OBSIDIAN_REST_URL=https://127.0.0.1:27124
OBSIDIAN_REST_API_KEY=COLE_SUA_API_KEY_AQUI
OBSIDIAN_FOLDER=Tech-Pulse
OBSIDIAN_VERIFY_SSL=false
OBSIDIAN_OPEN_AFTER_EXPORT=true

# Alternativa sem plugin — caminho absoluto do vault:
# OBSIDIAN_VAULT_PATH=C:\Users\stife\Documents\MeuVault
