# Copie para backend/.env e preencha OBSIDIAN_REST_API_KEY

OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
OLLAMA_TIMEOUT=180
OLLAMA_CONCURRENCY=3
# 5m = mantém na GPU entre chamadas; 0 = descarrega após cada uma
OLLAMA_KEEP_ALIVE=5m

# Plugin Local REST API (Obsidian → Settings → Community plugins)
OBSIDIAN_REST_URL=https://127.0.0.1:27124
OBSIDIAN_REST_API_KEY=COLE_SUA_API_KEY_AQUI
OBSIDIAN_FOLDER=Tech-Pulse
OBSIDIAN_VERIFY_SSL=false
OBSIDIAN_OPEN_AFTER_EXPORT=true

# Alternativa sem plugin — caminho absoluto do vault:
# OBSIDIAN_VAULT_PATH=C:\Users\stife\Documents\MeuVault
#
# Modo híbrido (recomendado): defina VAULT_PATH + REST_API_KEY juntos.
# Grava sempre no disco; REST só para abrir nota após exportar (Obsidian aberto).

# Groq Cloud API Configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-specdec

# Task Splitting Providers ("ollama" or "groq")
PROVIDER_SUMMARIZE=ollama
PROVIDER_ANALYZE=groq
PROVIDER_ORCHESTRATE=groq

# Feed Ingest Split Providers ("ollama" or "groq")
PROVIDER_TRIADOR=ollama
PROVIDER_TRADUTOR=ollama
PROVIDER_HYPE=groq
PROVIDER_UNIFIED=groq
